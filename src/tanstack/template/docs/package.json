{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run generate-schemas && dotenv -e .env.local -- vite dev --port 3005",
    "build": "bun run generate-schemas && dotenv -e .env.local -- vite build",
    "preview": "vite preview --port 3005",
    "lint": "bunx biome check .",
    "generate-schemas": "dotenv -e .env.local -- bun scripts/generate-schemas.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .turbo dist node_modules"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@trpc/client": "^11.8.1",
    "cms-renderer": "^0.6.6",
    "nitro": "^2.13.4",
    "superjson": "^2.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.1.0",
    "object-hash": "^3.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
